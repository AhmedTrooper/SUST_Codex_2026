# ==============================================================================
# SUST_CODEX_2026 ENVIRONMENT VARIABLES CONFIGURATION
# Copy this file to '.env' (which is ignored by Git) to customize local setup.
# ==============================================================================

# --- GENERAL BACKEND SERVICE CONFIGURATION ---
# Port the Axum backend binds to (defaults to 8080 if not set)
PORT=8080

# Logging level for Axum backend (error, warn, info, debug, trace)
RUST_LOG=info

# --- SECURITY & CORS ---
# Comma-separated list of allowed origins. Leave blank to allow any origin (*) in development.
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://my-front-end.railway.app
ALLOWED_ORIGINS=

# --- POSTGRESQL DATABASE CONFIGURATION (Railway provisioning ready) ---
# Connection URL format for PostgreSQL database
# Matching local docker-compose setup:
DATABASE_URL=postgresql://sust_codex_2026_user:sust_codex_2026_password@localhost:5432/sust_codex_2026_db

# --- REDIS CONFIGURATION (Railway provisioning ready) ---
# Redis cache connection host/URI
# Matching local docker-compose setup:
REDIS_URL=redis://localhost:6379

# --- MINIO / S3 STORAGE CONFIGURATION ---
# S3 credentials and endpoint configuration
# Matching local docker-compose setup:
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=supersecretpassword
S3_BUCKET=sust-codex-2026-bucket
